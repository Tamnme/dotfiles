// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "/bin/sh",
        "args": [
          "-c",
          "exec /opt/homebrew/bin/zellij attach -c \"$(basename \"$(dirname \"$PWD\")\")-$(basename \"$PWD\")\"",
        ],
      },
    },
    "working_directory": "current_project_directory",
    "font_family": "FiraMono Nerd Font",
  },
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed",
  },
  "languages": {
    "Rust": {
      "show_edit_predictions": true,
    },
    "Python": {
      "show_edit_predictions": true,
    },
  },
  "agent": {
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4o",
    },
  },
  "ssh_connections": [
    {
      "host": "52.139.219.196",
      "username": "azure",
      "args": [],
      "projects": [
        {
          "paths": ["~/code"],
        },
      ],
    },
    {
      "host": "10.88.9.100",
      "username": "root",
      "args": [],
      "projects": [
        {
          "paths": ["/root"],
        },
      ],
      "nickname": "Devyt-Epurchase",
    },
  ],
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Ayu Mirage",
  },
}
