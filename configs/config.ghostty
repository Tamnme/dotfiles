shell-integration = fish
command = /opt/homebrew/bin/zellij attach -c ghostty

macos-titlebar-style = transparent

# Unbind CMD+... keys so they will be forwarded to Zellij
keybind = cmd+t=unbind
keybind = cmd+n=unbind
keybind = cmd+w=unbind
keybind = cmd+left=unbind
keybind = cmd+right=unbind
keybind = cmd+up=unbind
keybind = cmd+down=unbind
keybind = cmd+shift+left=unbind
keybind = cmd+shift+right=unbind
keybind = opt+tab=unbind

# Always consume cmd+c so stray 'c' never leak to terminal when no selection
keybind = cmd+c=copy_to_clipboard

# Option+Arrow → send Alt+Arrow CSI (not bash word-jump esc) so zellij
# doesn't misread \ef as Alt+f (ToggleFloatingPanes). Fish binds \e[1;3D/C.
keybind = alt+left=csi:1;3D
keybind = alt+right=csi:1;3C

# Enable Option key as Alt for keybindings
# Use 'left' so right Option key can still type special characters
macos-option-as-alt = left
